# =============================================================================
# Palpito (bot + site) — copie para .env na raiz e preencha
# Um único arquivo: bot (Discord) + site (Next.js em dapp/)
# =============================================================================

# ---------- Discord (bot) ----------
DISCORD_TOKEN=seu_token_do_bot
DISCORD_CLIENT_ID=id_do_bot
DISCORD_GUILD_ID=id_do_servidor

# Banco SQLite unificado (todos os módulos)
DATABASE_PATH=./data/palpites.db

# ---------- Palpites ----------
API_FUTEBOL_KEY=sua_api_key
CAMPEONATO_ID=10
API_DAILY_LIMIT=100
VERIFICAR_RESULTADOS_CRON="*/30 * * * *"
ABRIR_RODADA_CRON="0 9 * * *"
DISCORD_CARGO_PALPITES_ID=

# ---------- Eventos ----------
STAFF_ROLE_IDS=
ADMIN_ROLE_IDS=
ADMIN_LOG_CHANNEL_ID=
CO_LOG_CHANNEL_ID=

# ---------- Pontos (ex-chiliz bot) ----------
CO_RANKING_CHANNEL_ID=

# ---------- Quiz ----------
# Painel em /quiz no dApp (NEXT_PUBLIC_APP_URL)

# ---------- Recompensas automáticas (pontos da comunidade) ----------
POINTS_REWARDS_ENABLED=true
POINTS_EVENT_PARTICIPATION=5
POINTS_QUIZ_PER_CORRECT=1
POINTS_PALPITE_EXATO=3
POINTS_PALPITE_VENCEDOR=1

# ---------- Google Sheets (opcional, eventos) ----------
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB_NAME=Eventos
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
# Link da planilha "Report das dinâmicas" (DM ao staff ao finalizar evento)
GOOGLE_SHEETS_REPORT_URL=https://docs.google.com/spreadsheets/d/1ppdfq5lIUAqx3N6YTjIgUFaocC34tqx0HJRZjipqV5w/edit?usp=sharing

# =============================================================================
# Modo on-chain (Copa CHZ) — opcional
# =============================================================================

CHILIZ_RPC_URL=https://spicy-rpc.chiliz.com/
CHILIZ_CHAIN_ID=88882
CHILIZ_SCAN_API_BASE_URL=https://scan-api.chiliz.com/api
CHILIZ_SCAN_API_KEY=
CHILIZ_PAYMENT_RECEIVER_ADDRESS=

# =============================================================================
# Square Cloud / deploy
# =============================================================================

DAPP_BASE_URL=https://seu-dapp.vercel.app
# true = bot sobe o site local junto (npm run dev no dapp/). false = deploy (Square Cloud/Vercel).
DAPP_AUTO_START=true
BOT_API_CORS_ORIGIN=https://seu-dapp.vercel.app

COPA_CAMPEONATO_ID=
COPA_ENTRADA_CHZ_DEFAULT=10
APOSTA_SESSION_TTL_MIN=30

# =============================================================================
# dApp (Next.js — pasta dapp/)
# =============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_NETWORK=spicy

BOT_API_URL=http://localhost:3001
NEXT_PUBLIC_BOT_API_URL=http://localhost:3001

NEXT_PUBLIC_DISCORD_GUILD_ID=

# Login do site (Quiz + painel /admin)
# ADMIN_USERNAME + ADMIN_PASSWORD definem o usuário bootstrap (Developer).
# Se o banco estiver vazio, ele é criado automaticamente.
# Se já existir, a senha é sincronizada com o .env ao reiniciar o bot.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
AUTH_SECRET=troque_por_uma_string_aleatoria_longa_min_16_chars

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
