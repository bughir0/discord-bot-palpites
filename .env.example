# =============================================================================
# Bot Discord — copie para .env e preencha
# =============================================================================

DISCORD_TOKEN=seu_token_do_bot
DISCORD_CLIENT_ID=id_do_bot
DISCORD_GUILD_ID=id_do_servidor_teste
API_FUTEBOL_KEY=sua_api_key
CAMPEONATO_ID=10
DATABASE_PATH=./data/palpites.db
API_DAILY_LIMIT=100
VERIFICAR_RESULTADOS_CRON=*/30 * * * *
ABRIR_RODADA_CRON=0 9 * * *
DISCORD_CARGO_PALPITES_ID=

# =============================================================================
# Modo on-chain (Copa CHZ) — opcional
# Formato atual: pagamentos por transferencia CHZ (sem contrato inteligente).
# Preencha CHILIZ_PAYMENT_RECEIVER_ADDRESS para ativar o modo CHZ.
# Se estiver vazio, o bot roda so Brasileirao free.
# =============================================================================

CHILIZ_RPC_URL=https://spicy-rpc.chiliz.com/
CHILIZ_CHAIN_ID=88882
CHILIZ_SCAN_API_BASE_URL=https://scan-api.chiliz.com/api
CHILIZ_SCAN_API_KEY=

# Modo sem contrato: pagamentos CHZ por transferencia simples para este endereco.
CHILIZ_PAYMENT_RECEIVER_ADDRESS=

DAPP_BASE_URL=http://localhost:3000
# Inicia o Next.js em dapp/ junto com o bot (padrao: sim quando DAPP_BASE_URL e localhost)
DAPP_AUTO_START=true
BOT_API_PORT=3001
COPA_CAMPEONATO_ID=
COPA_ENTRADA_CHZ_DEFAULT=10
APOSTA_SESSION_TTL_MIN=30

# =============================================================================
# Mini dApp (pasta dapp/) — copie dapp/.env.example para dapp/.env.local
# =============================================================================
