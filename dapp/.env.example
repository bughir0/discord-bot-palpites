# URL publica do dApp (Vercel ou localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Rede ativa: 'spicy' (testnet) ou 'chiliz' (mainnet)
NEXT_PUBLIC_NETWORK=spicy

# URL do bot (proxy server-side do Next em /bot-api)
BOT_API_URL=http://localhost:3001
# URL publica do bot (usada em mensagens de erro no browser)
NEXT_PUBLIC_BOT_API_URL=http://localhost:3001

# Guild padrao para carregar rodada/ranking no site
NEXT_PUBLIC_DISCORD_GUILD_ID=

# WalletConnect Cloud Project ID (https://cloud.walletconnect.com)
# Opcional em dev (usa ID publico do RainbowKit). Recomendado em producao.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
